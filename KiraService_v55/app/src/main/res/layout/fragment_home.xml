<?xml version="1.0" encoding="utf-8"?>
<!-- Layer 2+3: Chat Interface + Input Composer (Catppuccin Mocha Neural Glass) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#00000000">

    <!-- Layer 2: Header — 52dp Mantle strip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:background="#FF181825">

        <!-- K badge: 30×30dp, Lavender fill, dark text, tagged for rotation animation -->
        <TextView
            android:id="@+id/kBadge"
            android:tag="kBadge"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:text="K"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FF1E1E2E"
            android:gravity="center"
            android:background="#FFB4BEFE"/>

        <!-- Name + subtitle block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="10dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kira"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFCDD6F4"/>
            <!-- Subtitle: crossfades between ready/thinking/reasoning/composing -->
            <TextView
                android:id="@+id/headerSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ready"
                android:textSize="10sp"
                android:textColor="#FF9399B2"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- Status dot: Green when connected -->
        <View
            android:id="@+id/statusDot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="#FFA6E3A1"/>
    </LinearLayout>

    <!-- Header bottom border: Lavender 27% opacity, pulses to 35% when processing -->
    <View
        android:id="@+id/headerBorder"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#44B4BEFE"/>

    <!-- Chat scroll area -->
    <ScrollView
        android:id="@+id/chatScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:clipToPadding="false"
        android:scrollbars="none">
        <LinearLayout
            android:id="@+id/chatContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp"/>
    </ScrollView>

    <!-- Layer 3: Quick-action suggestion chips — horizontal scroll with edge fade -->
    <HorizontalScrollView
        android:id="@+id/suggestionsScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:requiresFadingEdge="horizontal"
        android:fadingEdgeLength="24dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp">
        <LinearLayout
            android:id="@+id/suggestionsRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"/>
    </HorizontalScrollView>

    <!-- Layer 3: Input Composer — Surface0 field with Lavender focus border -->
    <LinearLayout
        android:id="@+id/inputBar"
        android:tag="inputBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FF181825"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <!-- Input field: Surface0, 12dp corners, Lavender border on focus -->
        <EditText
            android:id="@+id/inputField"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="ask kira anything…"
            android:textColor="#FFCDD6F4"
            android:textColorHint="#FF6C7086"
            android:textSize="14sp"
            android:background="#FF313244"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:imeOptions="actionSend"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="4"/>

        <!-- Send button: Lavender circle, press spring animation -->
        <TextView
            android:id="@+id/sendBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="▶"
            android:textSize="13sp"
            android:gravity="center"
            android:textColor="#FF1E1E2E"
            android:background="#FFB4BEFE"
            android:layout_marginStart="8dp"/>

    </LinearLayout>
</LinearLayout>
