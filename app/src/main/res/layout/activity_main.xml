<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#0a0a0a">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🦀 KiraService"
        android:textSize="28sp"
        android:textColor="#00ff88"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Rust-powered Android automation"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#cccccc"
        android:fontFamily="monospace"
        android:background="#111111"
        android:padding="16dp"
        android:layout_marginBottom="32dp"
        android:text="Loading..." />

    <Button
        android:id="@+id/btnAccessibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable Accessibility Service"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#1a3a2a"
        android:textColor="#00ff88" />

    <Button
        android:id="@+id/btnShizuku"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Open Shizuku"
        android:backgroundTint="#1a1a3a"
        android:textColor="#8888ff" />

</LinearLayout>
