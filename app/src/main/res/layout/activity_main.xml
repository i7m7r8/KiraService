<?xml version="1.0" encoding="utf-8"?>
<!-- Kira v0.0.2 — Catppuccin Mocha shell -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#11111B">

    <!-- Star field — always behind everything -->
    <com.kira.service.ui.GalaxyView
        android:id="@+id/galaxyView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Content area -->
    <FrameLayout
        android:id="@+id/contentFrame"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"/>

    <!-- Floating pill nav bar -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="#F0181825"
        android:paddingTop="4dp"
        android:paddingBottom="12dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:elevation="12dp">

        <!-- KIRA tab -->
        <LinearLayout android:id="@+id/navHome"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical"
            android:gravity="center" android:clickable="true" android:focusable="true">
            <TextView android:id="@+id/navHomeIcon"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⬡" android:textSize="22sp" android:textColor="#B4BEFE"/>
            <TextView android:id="@+id/navHomeText"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="KIRA" android:textSize="8sp" android:textColor="#B4BEFE"
                android:fontFamily="monospace" android:letterSpacing="0.12"/>
        </LinearLayout>

        <!-- TOOLS tab -->
        <LinearLayout android:id="@+id/navAbilities"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical"
            android:gravity="center" android:clickable="true" android:focusable="true">
            <TextView android:id="@+id/navAbilitiesIcon"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚡" android:textSize="22sp" android:textColor="#45475A"/>
            <TextView android:id="@+id/navAbilitiesText"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="TOOLS" android:textSize="8sp" android:textColor="#45475A"
                android:fontFamily="monospace" android:letterSpacing="0.12"/>
        </LinearLayout>

        <!-- LOG tab -->
        <LinearLayout android:id="@+id/navHistory"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical"
            android:gravity="center" android:clickable="true" android:focusable="true">
            <TextView android:id="@+id/navHistoryIcon"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="◫" android:textSize="22sp" android:textColor="#45475A"/>
            <TextView android:id="@+id/navHistoryText"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="LOG" android:textSize="8sp" android:textColor="#45475A"
                android:fontFamily="monospace" android:letterSpacing="0.12"/>
        </LinearLayout>

        <!-- SYS tab -->
        <LinearLayout android:id="@+id/navSettings"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical"
            android:gravity="center" android:clickable="true" android:focusable="true">
            <TextView android:id="@+id/navSettingsIcon"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⊞" android:textSize="22sp" android:textColor="#45475A"/>
            <TextView android:id="@+id/navSettingsText"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SYS" android:textSize="8sp" android:textColor="#45475A"
                android:fontFamily="monospace" android:letterSpacing="0.12"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
