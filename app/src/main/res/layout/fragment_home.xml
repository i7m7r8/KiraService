<?xml version="1.0" encoding="utf-8"?>
<!-- Kira v0.0.2 — Chat fragment — Catppuccin Mocha -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#00000000">

    <!-- Header bar — Mantle surface, lavender accent strip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#E6181825">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Lavender K pill -->
            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="#FFB4BEFE">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="K"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1E1E2E"
                    android:fontFamily="sans-serif-medium"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kira"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#CDD6F4"
                    android:fontFamily="sans-serif-medium"/>
                <TextView
                    android:id="@+id/headerSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="autonomous agent · ready"
                    android:textSize="10sp"
                    android:textColor="#6C7086"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <!-- Live dot -->
            <View
                android:id="@+id/statusDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="#FFA6E3A1"/>
        </LinearLayout>

        <!-- Lavender accent line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#44B4BEFE"/>
    </LinearLayout>

    <!-- Chat scroll -->
    <ScrollView
        android:id="@+id/chatScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:clipToPadding="false"
        android:scrollbars="none">
        <LinearLayout
            android:id="@+id/chatContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp"/>
    </ScrollView>

    <!-- Suggestion chips -->
    <HorizontalScrollView
        android:id="@+id/suggestionsScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">
        <LinearLayout
            android:id="@+id/suggestionsRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"/>
    </HorizontalScrollView>

    <!-- Input bar — Mantle bg -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#F2181825"
        android:paddingStart="12dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/inputField"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="message kira  ·  /agent for autopilot"
            android:textColor="#CDD6F4"
            android:textColorHint="#45475A"
            android:textSize="14sp"
            android:background="#CC313244"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="11dp"
            android:paddingBottom="11dp"
            android:imeOptions="actionSend"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="4"/>

        <!-- Send button — lavender pill -->
        <TextView
            android:id="@+id/sendBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="▶"
            android:textSize="14sp"
            android:gravity="center"
            android:textColor="#1E1E2E"
            android:background="#FFB4BEFE"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</LinearLayout>
