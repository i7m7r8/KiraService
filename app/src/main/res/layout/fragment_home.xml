<?xml version="1.0" encoding="utf-8"?>
<!--
  Kira v0.0.1 — Home / Chat fragment
  Terminal aesthetic: obsidian panels, crimson accents, monospace hints
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#00000000">

    <!-- ── HEADER ─────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="16dp"
        android:paddingTop="18dp"
        android:paddingBottom="10dp">

        <!-- K glyph — filled crimson square, no rounded corners -->
        <LinearLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="#DC143C"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="K"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KIRA"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#DC143C"
                android:fontFamily="monospace"
                android:letterSpacing="0.3"/>

            <TextView
                android:id="@+id/headerSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="autonomous agent · ready"
                android:textSize="10sp"
                android:textColor="#333355"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- Live indicator: blinking dot -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/statusDot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="#DC143C"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" LIVE"
                android:textSize="8sp"
                android:textColor="#3a0010"
                android:fontFamily="monospace"
                android:layout_marginEnd="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Crimson divider — sharp, 1px -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33DC143C"/>

    <!-- ── CHAT AREA ──────────────────────────────────────────────────── -->
    <ScrollView
        android:id="@+id/chatScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:clipToPadding="false"
        android:scrollbars="none">
        <LinearLayout
            android:id="@+id/chatContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp"/>
    </ScrollView>

    <!-- ── SUGGESTION CHIPS ───────────────────────────────────────────── -->
    <HorizontalScrollView
        android:id="@+id/suggestionsScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="4dp"
        android:paddingTop="4dp">
        <LinearLayout
            android:id="@+id/suggestionsRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"/>
    </HorizontalScrollView>

    <!-- ── INPUT BAR ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#EE06060f"
        android:paddingStart="12dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <!-- Input field — glass panel, monospace hint -->
        <EditText
            android:id="@+id/inputField"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="message kira  ·  /agent for autopilot"
            android:textColor="#FFFFFF"
            android:textColorHint="#222240"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:background="#1500000A"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:imeOptions="actionSend"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="4"/>

        <!-- Send — flat crimson square, no shadow -->
        <TextView
            android:id="@+id/sendBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="▶"
            android:textSize="14sp"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:background="#DC143C"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</LinearLayout>
