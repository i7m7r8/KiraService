<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#0f0f0f">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingBottom="32dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingTop="20dp" android:paddingBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Settings" android:textSize="32sp" android:textStyle="bold" android:textColor="#ff8c00"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Configure API and options" android:textSize="14sp" android:textColor="#888888"/>
        </LinearLayout>

        <!-- Shizuku status card -->
        <LinearLayout android:id="@+id/shizukuStatus"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="#1a2a1a"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingTop="14dp" android:paddingBottom="14dp"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp" android:gravity="center_vertical"
            android:clickable="true" android:focusable="true">
            <TextView android:id="@+id/shizukuIcon"
                android:layout_width="36dp" android:layout_height="36dp"
                android:text="✓" android:textSize="18sp" android:gravity="center"
                android:textColor="#00cc66" android:background="#003311"
                android:layout_marginEnd="12dp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/shizukuTitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Shizuku Connected" android:textColor="#00cc66"
                    android:textSize="13sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Tap to configure Shizuku" android:textColor="#888888" android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Accessibility button -->
        <LinearLayout android:id="@+id/settingAccessibility"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="#1a1a1a"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingTop="14dp" android:paddingBottom="14dp"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp" android:gravity="center_vertical"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="36dp" android:layout_height="36dp"
                android:text="♿" android:textSize="18sp" android:gravity="center"
                android:layout_marginEnd="12dp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Accessibility Service" android:textColor="#ffffff" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Enable for screen control" android:textColor="#888888" android:textSize="12sp"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textColor="#666666" android:textSize="20sp"/>
        </LinearLayout>

        <!-- API Settings -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="API SETTINGS" android:textSize="11sp" android:textColor="#ff8c00"
            android:textStyle="bold" android:paddingStart="20dp" android:paddingBottom="6dp" android:letterSpacing="0.1"/>

        <LinearLayout android:id="@+id/settingApiKey"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="#1a1a1a"
            android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="14dp" android:paddingBottom="14dp"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginBottom="2dp"
            android:gravity="center_vertical" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="36dp" android:layout_height="36dp" android:text="🔑" android:textSize="18sp" android:gravity="center" android:layout_marginEnd="12dp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="API Key" android:textColor="#ffffff" android:textSize="14sp"/>
                <TextView android:id="@+id/apiKeyHint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Not set" android:textColor="#888888" android:textSize="12sp"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#444444" android:textSize="20sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/settingModel"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="#1a1a1a"
            android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="14dp" android:paddingBottom="14dp"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginBottom="2dp"
            android:gravity="center_vertical" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="36dp" android:layout_height="36dp" android:text="🤖" android:textSize="18sp" android:gravity="center" android:layout_marginEnd="12dp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Model" android:textColor="#ffffff" android:textSize="14sp"/>
                <TextView android:id="@+id/modelHint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Not set" android:textColor="#888888" android:textSize="12sp"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#444444" android:textSize="20sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/settingBaseUrl"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="#1a1a1a"
            android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="14dp" android:paddingBottom="14dp"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginBottom="16dp"
            android:gravity="center_vertical" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="36dp" android:layout_height="36dp" android:text="🌐" android:textSize="18sp" android:gravity="center" android:layout_marginEnd="12dp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Base URL" android:textColor="#ffffff" android:textSize="14sp"/>
                <TextView android:id="@+id/baseUrlHint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Not set" android:textColor="#888888" android:textSize="12sp"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#444444" android:textSize="20sp"/>
        </LinearLayout>

        <!-- Telegram -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="TELEGRAM BOT" android:textSize="11sp" android:textColor="#ff8c00"
            android:textStyle="bold" android:paddingStart="20dp" android:paddingBottom="6dp" android:letterSpacing="0.1"/>

        <LinearLayout android:id="@+id/settingTgToken"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="#1a1a1a"
            android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="14dp" android:paddingBottom="14dp"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginBottom="2dp"
            android:gravity="center_vertical" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="36dp" android:layout_height="36dp" android:text="✈" android:textSize="18sp" android:gravity="center" android:layout_marginEnd="12dp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bot Token" android:textColor="#ffffff" android:textSize="14sp"/>
                <TextView android:id="@+id/tgTokenHint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Not set" android:textColor="#888888" android:textSize="12sp"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#444444" android:textSize="20sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/settingTgId"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="#1a1a1a"
            android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="14dp" android:paddingBottom="14dp"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginBottom="16dp"
            android:gravity="center_vertical" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="36dp" android:layout_height="36dp" android:text="👤" android:textSize="18sp" android:gravity="center" android:layout_marginEnd="12dp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Your Telegram ID" android:textColor="#ffffff" android:textSize="14sp"/>
                <TextView android:id="@+id/tgIdHint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Get from @userinfobot" android:textColor="#888888" android:textSize="12sp"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#444444" android:textSize="20sp"/>
        </LinearLayout>

        <!-- About -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="ABOUT" android:textSize="11sp" android:textColor="#ff8c00"
            android:textStyle="bold" android:paddingStart="20dp" android:paddingBottom="6dp" android:letterSpacing="0.1"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="#1a1a1a"
            android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="14dp" android:paddingBottom="14dp"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp">
            <TextView android:layout_width="36dp" android:layout_height="36dp" android:text="🦀" android:textSize="18sp" android:gravity="center" android:layout_marginEnd="12dp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kira Agent v3.0" android:textColor="#ffffff" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rust-powered Android AI — No Termux needed" android:textColor="#888888" android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
