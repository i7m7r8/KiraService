<?xml version="1.0" encoding="utf-8"?>
<!--
  Kira Settings v40 — Modern Rust/Terminal-inspired design
  Design language: Dark glass cards, crimson accents, monospace hints,
  left-border highlights, no fake Android chrome
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00000000"
    android:scrollbars="none"
    android:fillViewport="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="80dp">

        <!-- ── HEADER ─────────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingTop="24dp" android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#DC143C"
                android:letterSpacing="0.02"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="configure kira agent"
                android:textSize="12sp"
                android:textColor="#444466"
                android:fontFamily="monospace"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- ── STATUS ROW (3 cards) ──────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:paddingBottom="16dp">

            <!-- Shizuku -->
            <LinearLayout
                android:id="@+id/cardShizuku"
                android:layout_width="0dp" android:layout_height="80dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#0d0d1a"
                android:layout_marginEnd="6dp"
                android:clickable="true" android:focusable="true"
                android:paddingTop="10dp" android:paddingBottom="10dp">
                <!-- left accent bar drawn via background layering not possible in XML, use padding -->
                <TextView
                    android:id="@+id/shizukuIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡"
                    android:textSize="22sp"/>
                <TextView
                    android:id="@+id/shizukuTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shizuku"
                    android:textColor="#DC143C"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginTop="3dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ADB shell"
                    android:textColor="#333355"
                    android:textSize="9sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <!-- Accessibility -->
            <LinearLayout
                android:id="@+id/cardAccessibility"
                android:layout_width="0dp" android:layout_height="80dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#0d0d1a"
                android:layout_marginEnd="6dp"
                android:clickable="true" android:focusable="true"
                android:paddingTop="10dp" android:paddingBottom="10dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👁"
                    android:textSize="22sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Screen"
                    android:textColor="#ffaa00"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginTop="3dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="accessibility"
                    android:textColor="#333355"
                    android:textSize="9sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <!-- Notifications -->
            <LinearLayout
                android:id="@+id/cardNotifListener"
                android:layout_width="0dp" android:layout_height="80dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#0d0d1a"
                android:clickable="true" android:focusable="true"
                android:paddingTop="10dp" android:paddingBottom="10dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔔"
                    android:textSize="22sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notifs"
                    android:textColor="#4488ff"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginTop="3dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="listener"
                    android:textColor="#333355"
                    android:textSize="9sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ── SECTION: AI MODEL ─────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI MODEL"
            android:textSize="10sp"
            android:textColor="#DC143C"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:paddingStart="20dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:fontFamily="monospace"/>

        <!-- API Key -->
        <LinearLayout android:id="@+id/rowApiKey"
            style="@style/SettingsRow">
            <TextView style="@style/SettingsIcon" android:text="🔑"/>
            <LinearLayout style="@style/SettingsTextBlock">
                <TextView style="@style/SettingsLabel" android:text="API Key"/>
                <TextView android:id="@+id/apiKeyHint" style="@style/SettingsHint" android:text="tap to set"/>
            </LinearLayout>
            <TextView style="@style/SettingsChevron"/>
        </LinearLayout>

        <!-- Base URL -->
        <LinearLayout android:id="@+id/rowBaseUrl"
            style="@style/SettingsRow">
            <TextView style="@style/SettingsIcon" android:text="🌐"/>
            <LinearLayout style="@style/SettingsTextBlock">
                <TextView style="@style/SettingsLabel" android:text="Base URL"/>
                <TextView android:id="@+id/baseUrlHint" style="@style/SettingsHint" android:text="api.groq.com/openai/v1"/>
            </LinearLayout>
            <TextView style="@style/SettingsChevron"/>
        </LinearLayout>

        <!-- Model -->
        <LinearLayout android:id="@+id/rowModel"
            style="@style/SettingsRow">
            <TextView style="@style/SettingsIcon" android:text="🧠"/>
            <LinearLayout style="@style/SettingsTextBlock">
                <TextView style="@style/SettingsLabel" android:text="Chat Model"/>
                <TextView android:id="@+id/modelHint" style="@style/SettingsHint" android:text="llama-3.1-8b-instant"/>
            </LinearLayout>
            <TextView style="@style/SettingsChevron"/>
        </LinearLayout>

        <!-- Vision Model -->
        <LinearLayout android:id="@+id/rowVision"
            style="@style/SettingsRow">
            <TextView style="@style/SettingsIcon" android:text="👁"/>
            <LinearLayout style="@style/SettingsTextBlock">
                <TextView style="@style/SettingsLabel" android:text="Vision Model"/>
                <TextView android:id="@+id/visionHint" style="@style/SettingsHint" android:text="for screen analysis"/>
            </LinearLayout>
            <TextView style="@style/SettingsChevron"/>
        </LinearLayout>

        <!-- Provider — special: shows active provider chip -->
        <LinearLayout android:id="@+id/rowProvider"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:background="#BB0a0a18"
            android:paddingStart="16dp" android:paddingEnd="12dp"
            android:layout_marginBottom="1dp"
            android:gravity="center_vertical"
            android:clickable="true" android:focusable="true">

            <TextView style="@style/SettingsIcon" android:text="⚡"/>
            <LinearLayout style="@style/SettingsTextBlock">
                <TextView style="@style/SettingsLabel" android:text="AI Provider"/>
                <TextView android:id="@+id/providerHint" style="@style/SettingsHint" android:text="Groq (active)"/>
            </LinearLayout>
            <!-- Active provider chip -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:text="switch"
                android:textSize="10sp"
                android:textColor="#DC143C"
                android:background="#220a0a"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:gravity="center"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- ── SECTION: AGENT ────────────────────────────────────────────── -->
        <TextView style="@style/SectionHeader" android:text="AGENT BEHAVIOR"
            android:layout_marginTop="12dp"/>

        <LinearLayout android:id="@+id/rowMaxSteps" style="@style/SettingsRow">
            <TextView style="@style/SettingsIcon" android:text="🎯"/>
            <LinearLayout style="@style/SettingsTextBlock">
                <TextView style="@style/SettingsLabel" android:text="Max Steps"/>
                <TextView android:id="@+id/maxStepsHint" style="@style/SettingsHint" android:text="25 steps"/>
            </LinearLayout>
            <TextView style="@style/SettingsChevron"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/rowAutoApprove" style="@style/SettingsRow">
            <TextView style="@style/SettingsIcon" android:text="✅"/>
            <LinearLayout style="@style/SettingsTextBlock">
                <TextView style="@style/SettingsLabel" android:text="Auto-Approve Tools"/>
                <TextView style="@style/SettingsHint" android:text="run tools without confirm"/>
            </LinearLayout>
            <TextView android:id="@+id/autoApproveToggle"
                android:layout_width="48dp" android:layout_height="26dp"
                android:text="ON" android:textSize="10sp"
                android:gravity="center"
                android:textColor="#DC143C"
                android:background="#1a0508"
                android:textStyle="bold"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/rowHeartbeat" style="@style/SettingsRow">
            <TextView style="@style/SettingsIcon" android:text="⏲"/>
            <LinearLayout style="@style/SettingsTextBlock">
                <TextView style="@style/SettingsLabel" android:text="Heartbeat"/>
                <TextView android:id="@+id/heartbeatHint" style="@style/SettingsHint" android:text="30 min"/>
            </LinearLayout>
            <TextView style="@style/SettingsChevron"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/rowPersona" style="@style/SettingsRow">
            <TextView style="@style/SettingsIcon" android:text="🎭"/>
            <LinearLayout style="@style/SettingsTextBlock">
                <TextView style="@style/SettingsLabel" android:text="Agent Persona"/>
                <TextView android:id="@+id/personaHint" style="@style/SettingsHint" android:text="You are Kira…"/>
            </LinearLayout>
            <TextView style="@style/SettingsChevron"/>
        </LinearLayout>

        <!-- ── SECTION: TELEGRAM ─────────────────────────────────────────── -->
        <TextView style="@style/SectionHeader" android:text="TELEGRAM BOT"
            android:layout_marginTop="12dp"/>

        <!-- Telegram card — distinctive blue tint -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#AA080e18"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingTop="14dp" android:paddingBottom="14dp"
            android:layout_marginBottom="1dp">

            <!-- Telegram header with icon -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✈"
                    android:textSize="24sp"
                    android:textColor="#2196F3"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Telegram Integration"
                    android:textColor="#ddddee"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingStart="10dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@BotFather"
                    android:textColor="#1a4a7a"
                    android:textSize="10sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <!-- Bot Token row -->
            <LinearLayout android:id="@+id/rowTgToken"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:background="#110e1a"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="2dp"
                android:clickable="true" android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOKEN"
                    android:textColor="#1a5a8a"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:layout_marginEnd="10dp"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bot Token"
                        android:textColor="#ccccdd"
                        android:textSize="13sp"/>
                    <TextView android:id="@+id/tgTokenHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="not configured"
                        android:textColor="#2a4a6a"
                        android:textSize="10sp"
                        android:fontFamily="monospace"/>
                </LinearLayout>
                <TextView style="@style/SettingsChevron"/>
            </LinearLayout>

            <!-- User ID row -->
            <LinearLayout android:id="@+id/rowTgId"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:background="#110e1a"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:gravity="center_vertical"
                android:clickable="true" android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="USER"
                    android:textColor="#1a5a8a"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:layout_marginEnd="10dp"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Allowed User ID"
                        android:textColor="#ccccdd"
                        android:textSize="13sp"/>
                    <TextView android:id="@+id/tgIdHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 = anyone"
                        android:textColor="#2a4a6a"
                        android:textSize="10sp"
                        android:fontFamily="monospace"/>
                </LinearLayout>
                <TextView style="@style/SettingsChevron"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ── SECTION: INTERFACE ────────────────────────────────────────── -->
        <TextView style="@style/SectionHeader" android:text="INTERFACE"
            android:layout_marginTop="12dp"/>

        <LinearLayout android:id="@+id/rowUserName" style="@style/SettingsRow">
            <TextView style="@style/SettingsIcon" android:text="👤"/>
            <LinearLayout style="@style/SettingsTextBlock">
                <TextView style="@style/SettingsLabel" android:text="Your Name"/>
                <TextView android:id="@+id/userNameHint" style="@style/SettingsHint" android:text="User"/>
            </LinearLayout>
            <TextView style="@style/SettingsChevron"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/rowFloating" style="@style/SettingsRow">
            <TextView style="@style/SettingsIcon" android:text="💬"/>
            <LinearLayout style="@style/SettingsTextBlock">
                <TextView style="@style/SettingsLabel" android:text="Floating Window"/>
                <TextView style="@style/SettingsHint" android:text="overlay bubble"/>
            </LinearLayout>
            <TextView android:id="@+id/floatingToggle"
                android:layout_width="48dp" android:layout_height="26dp"
                android:text="OFF" android:textSize="10sp"
                android:gravity="center"
                android:textColor="#444444"
                android:background="#1a1a1a"
                android:textStyle="bold"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- ── SECTION: MEMORY ───────────────────────────────────────────── -->
        <TextView style="@style/SectionHeader" android:text="MEMORY"
            android:layout_marginTop="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#AA0a0a16"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingTop="12dp" android:paddingBottom="12dp"
            android:layout_marginBottom="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView style="@style/SettingsIcon" android:text="🧠"/>
                <LinearLayout style="@style/SettingsTextBlock">
                    <TextView style="@style/SettingsLabel" android:text="Stored Facts"/>
                    <TextView android:id="@+id/memoryHint" style="@style/SettingsHint" android:text="loading…"/>
                </LinearLayout>
                <TextView android:id="@+id/memoryClearBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="clear"
                    android:textColor="#441111"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:paddingStart="12dp"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <TextView android:id="@+id/memoryContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#446644"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:background="#AA050508"
                android:padding="8dp"
                android:visibility="gone"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/rowHistory" style="@style/SettingsRow">
            <TextView style="@style/SettingsIcon" android:text="📂"/>
            <LinearLayout style="@style/SettingsTextBlock">
                <TextView style="@style/SettingsLabel" android:text="Conversation History"/>
                <TextView android:id="@+id/historySettingHint" style="@style/SettingsHint" android:text="tap to clear"/>
            </LinearLayout>
            <TextView style="@style/SettingsChevron"/>
        </LinearLayout>

        <!-- ── SECTION: TOOLS ────────────────────────────────────────────── -->
        <TextView style="@style/SectionHeader" android:text="TOOLS &amp; AUTOMATION"
            android:layout_marginTop="12dp"/>

        <LinearLayout android:id="@+id/rowSkills" style="@style/SettingsRow">
            <TextView style="@style/SettingsIcon" android:text="⚡"/>
            <LinearLayout style="@style/SettingsTextBlock">
                <TextView style="@style/SettingsLabel" android:text="Skills"/>
                <TextView android:id="@+id/skillsHint" style="@style/SettingsHint" android:text="176+ built-in tools"/>
            </LinearLayout>
            <TextView style="@style/SettingsChevron"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/rowCheckpoints" style="@style/SettingsRow">
            <TextView style="@style/SettingsIcon" android:text="📌"/>
            <LinearLayout style="@style/SettingsTextBlock">
                <TextView style="@style/SettingsLabel" android:text="Task Checkpoints"/>
                <TextView android:id="@+id/checkpointsHint" style="@style/SettingsHint" android:text="resume paused tasks"/>
            </LinearLayout>
            <TextView style="@style/SettingsChevron"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/rowAuditLog" style="@style/SettingsRow">
            <TextView style="@style/SettingsIcon" android:text="📋"/>
            <LinearLayout style="@style/SettingsTextBlock">
                <TextView style="@style/SettingsLabel" android:text="Audit Log"/>
                <TextView android:id="@+id/auditHint" style="@style/SettingsHint" android:text="all tool calls logged"/>
            </LinearLayout>
            <TextView style="@style/SettingsChevron"/>
        </LinearLayout>

        <!-- ── SECTION: RUST ENGINE ──────────────────────────────────────── -->
        <TextView style="@style/SectionHeader" android:text="RUST ENGINE v9"
            android:layout_marginTop="12dp"/>

        <LinearLayout android:id="@+id/rowRustStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#AA060610"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingTop="12dp" android:paddingBottom="12dp"
            android:layout_marginBottom="1dp"
            android:clickable="true" android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView style="@style/SettingsIcon" android:text="📊"/>
                <LinearLayout style="@style/SettingsTextBlock">
                    <TextView style="@style/SettingsLabel" android:text="Engine Stats"/>
                    <TextView android:id="@+id/rustStatsHint" style="@style/SettingsHint" android:text="localhost:7070 · tap to load"/>
                </LinearLayout>
                <TextView android:id="@+id/rustRefreshBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⟳"
                    android:textColor="#DC143C"
                    android:textSize="18sp"
                    android:paddingStart="12dp"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <TextView android:id="@+id/rustStatsContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#336633"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:background="#AA030308"
                android:padding="10dp"
                android:visibility="gone"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- ── SECTION: ABOUT ────────────────────────────────────────────── -->
        <TextView style="@style/SectionHeader" android:text="ABOUT"
            android:layout_marginTop="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#AA060610"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingTop="16dp" android:paddingBottom="16dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="#1a0a00"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="K"
                    android:textSize="24sp"
                    android:textColor="#DC143C"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kira Agent v9.0"
                    android:textColor="#DC143C"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rust core + Java · OpenClaw architecture"
                    android:textColor="#333355"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="2dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="made with ♥ by Imran"
                    android:textColor="#DC143C"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- spacer -->
        <View android:layout_width="match_parent" android:layout_height="20dp"/>

    </LinearLayout>
</ScrollView>
