<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name">Kira</string>
    <string name="accessibility_description">Gives Kira AI full phone control including screen reading, tapping, typing, and notifications.</string>

    <!-- ── Catppuccin Mocha — pure android theme, no Material dependency ──── -->
    <style name="AppTheme" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">#FF11111B</item>
        <item name="android:statusBarColor">#FF11111B</item>
        <item name="android:navigationBarColor">#FF181825</item>
        <item name="android:textColorPrimary">#FFCDD6F4</item>
        <item name="android:textColorSecondary">#FF9399B2</item>
        <item name="android:editTextColor">#FFCDD6F4</item>
        <item name="android:colorControlActivated">#FFB4BEFE</item>
        <item name="android:colorControlHighlight">#22B4BEFE</item>
        <item name="android:colorAccent">#FFB4BEFE</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Activity</item>
    </style>

    <!-- ── Setup Theme ───────────────────────────────────────────────────── -->
    <style name="SetupTheme" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">#FF11111B</item>
        <item name="android:statusBarColor">#FF11111B</item>
        <item name="android:textColorPrimary">#FFCDD6F4</item>
        <item name="android:editTextColor">#FFCDD6F4</item>
        <item name="android:colorControlActivated">#FFB4BEFE</item>
        <item name="android:colorAccent">#FFB4BEFE</item>
    </style>

    <!-- ── Settings row base ─────────────────────────────────────────────── -->
    <style name="SettingsRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:background">#CC1E1E2E</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:layout_marginBottom">1dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <!-- ── Settings icon box ─────────────────────────────────────────────── -->
    <style name="SettingsIcon">
        <item name="android:layout_width">36dp</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">18sp</item>
        <item name="android:layout_marginEnd">14dp</item>
    </style>

    <!-- ── Settings text block ───────────────────────────────────────────── -->
    <style name="SettingsTextBlock">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>

    <!-- ── Settings label ────────────────────────────────────────────────── -->
    <style name="SettingsLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#FFCDD6F4</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- ── Settings hint ─────────────────────────────────────────────────── -->
    <style name="SettingsHint">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#FF9399B2</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <!-- ── Chevron › ─────────────────────────────────────────────────────── -->
    <style name="SettingsChevron">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:text">›</item>
        <item name="android:textColor">#FF585B70</item>
        <item name="android:textSize">24sp</item>
        <item name="android:paddingStart">8dp</item>
    </style>

    <!-- ── Section header ────────────────────────────────────────────────── -->
    <style name="SectionHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">#FFB4BEFE</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Shape styles removed - not needed without MaterialComponents -->
</resources>
